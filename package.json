{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "npm --prefix backend install && npm --prefix frontend install --include=dev && npm --prefix frontend run build",
    "dev": "node start-dev.js",
    "dev:check": "node start-dev.js --check-only",
    "dev:unix": "bash START_BACKEND_FRONTEND.sh",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm --prefix frontend run build",
    "start": "node backend/index.js",
    "lint": "npm --prefix frontend run lint",
    "preview": "npm --prefix frontend run preview"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
