# ==============================================================================
# NATURANZA FOOD — BACKEND PRODUCTION ENVIRONMENT (REFERENCE / TEMPLATE)
# ==============================================================================
# This file is a CHECKLIST, not a secret store. It contains placeholders only.
#
# On Hostinger: DO NOT upload a real .env. Instead paste these keys (with your
# real values) into  hPanel -> your Node.js App -> Environment Variables.
# Values set there become real process.env entries that dotenv will NOT override.
#
# For local development, copy this to backend/.env and fill in dev values.
# NEVER commit a filled-in .env — only this .env.example is tracked.
# ==============================================================================

# --- Runtime --------------------------------------------------------------
NODE_ENV=production
# Hostinger injects PORT automatically. Leave unset there; 5000 is the local default.
# PORT=5000
# App sits behind Hostinger's reverse proxy → trust X-Forwarded-* headers.
TRUST_PROXY=true
IP_LOOKUP_TIMEOUT_MS=2000

# --- MySQL Database (from hPanel -> Databases -> MySQL) --------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_hostinger_db_user
DB_PASSWORD=your_hostinger_db_password
DB_NAME=your_hostinger_db_name
DB_CONNECTION_LIMIT=10

# --- Security toggles (all ON in production) -------------------------------
ENABLE_RATE_LIMITS=true
ENABLE_CSRF_PROTECTION=true
ENFORCE_HTTPS=true
COOKIE_SECURE=true

# --- JWT -------------------------------------------------------------------
# Fresh 64-byte secret generated for this deployment. Replace if you prefer your
# own:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=38142dfbc2ae4e3c0de5c09159d66ebbf7e05dca780d2684247387a21cd4adcd50820168ed8ef80cc33b476c8d2dff7a21fcb4fe689571e4877ad429825ec222
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# --- CORS (your live domain, apex + www) -----------------------------------
CORS_ALLOWED_ORIGINS=https://naturanzafood.com,https://www.naturanzafood.com

# --- Google OAuth (Google Cloud Console -> Credentials) --------------------
# ROTATE the client secret before going live (the old one was exposed in chat).
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_rotated_google_client_secret

# --- Default super-admin seed ----------------------------------------------
# Set a NEW strong password (>= 12 chars). After first successful login, flip
# SEED_DEFAULT_ADMIN to false and redeploy so it stops re-seeding on boot.
SEED_DEFAULT_ADMIN=true
DEFAULT_ADMIN_NAME=Super Admin
DEFAULT_ADMIN_EMAIL=naturanzafood@gmail.com
DEFAULT_ADMIN_PASSWORD=set_a_new_strong_password_here

# --- Email (Gmail SMTP) -----------------------------------------------------
# ROTATE this Gmail App Password before going live (the old one was exposed).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=naturanzafood@gmail.com
SMTP_PASS=your_rotated_gmail_app_password
EMAIL_FROM_NAME=Naturanza Food
EMAIL_FROM=naturanzafood@gmail.com

# --- Public URLs ------------------------------------------------------------
FRONTEND_URL=https://naturanzafood.com
CLIENT_URL=https://naturanzafood.com
ADMIN_URL=https://naturanzafood.com/admin/login

# --- Business info ----------------------------------------------------------
BUSINESS_LEGAL_NAME=Naturanza Food
BUSINESS_WEBSITE=www.naturanzafood.com
BUSINESS_SUPPORT_EMAIL=support@naturanzafood.com
BUSINESS_SUPPORT_PHONE=+92 340 9502646
