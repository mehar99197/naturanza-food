# ============================================
# NATURANZA FOODS - FRONTEND CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ============================================
# API Configuration
# ============================================
# Backend API URL (use production URL in production)
VITE_API_URL=https://your-backend-api.com/api

# ============================================
# Public Site URL
# ============================================
# Used in SEO meta tags, OpenGraph, structured data, canonical/blog URLs.
# Set this to the same URL your storefront is served from (no trailing slash).
VITE_SITE_URL=https://naturanzafood.com

# ============================================
# Google OAuth Configuration
# ============================================
# Get your Client ID from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ============================================
# Optional: Invoice Download Timeout (milliseconds)
# ============================================
VITE_INVOICE_DOWNLOAD_TIMEOUT_MS=120000

# ============================================
# Optional: Expose to network (for Docker/containers)
# ============================================
# VITE_HOST_NETWORK=true

# ============================================
# Google Analytics 4 Configuration
# ============================================
# Get your Measurement ID from: https://analytics.google.com
# Create a GA4 property and get the G-XXXXXXXXXX ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX